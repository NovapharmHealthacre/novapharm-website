{
  "name": "novapharm-healthcare-website",
  "version": "3.2.0",
  "private": true,
  "type": "module",
  "description": "Enterprise-grade NovaPharm Healthcare website with premium image-led public experience, secure portal, linked entity authority, SEO/GEO controls, and SharePoint integration architecture.",
  "scripts": {
    "build": "node scripts/build-site.mjs",
    "build:base": "node scripts/build-pages.mjs",
    "seo:enhance": "node scripts/enhance-seo-authority.mjs",
    "seo:validate": "node scripts/validate-seo-authority.mjs && node scripts/validate-social-authority.mjs",
    "seo:indexnow:dry-run": "node scripts/indexnow.mjs",
    "visual:validate": "node scripts/validate-visual-refinement.mjs",
    "visual:modules": "node scripts/validate-module-media-sanity.mjs",
    "start": "node server.mjs",
    "start:production": "node --import @azure/monitor-opentelemetry/loader server.mjs",
    "portal:local": "node scripts/local-portal/start.mjs",
    "portal:local:stop": "node scripts/local-portal/stop.mjs",
    "portal:local:reset": "node scripts/local-portal/reset.mjs",
    "portal:local:test": "node scripts/test-local-owner-portal.mjs",
    "portal:local:backup-test": "node scripts/local-portal/backup-test.mjs",
    "portal:local:import-nutraxin": "node scripts/import-nutraxin-catalogue.mjs",
    "docs:enterprise": "node scripts/generate-enterprise-portal-docs.mjs",
    "prepare:release": "npm run build",
    "validate": "node scripts/validate-site.mjs && npm run seo:validate && node scripts/check-links.mjs && node scripts/validate-app.mjs && node scripts/validate-domain.mjs && node scripts/audit-public-claims.mjs",
    "validate:site": "node scripts/validate-site.mjs",
    "validate:app": "node scripts/validate-app.mjs",
    "validate:domain": "node scripts/validate-domain.mjs",
    "audit:claims": "node scripts/audit-public-claims.mjs",
    "check:links": "node scripts/check-links.mjs",
    "syntax": "node scripts/check-syntax.mjs && node scripts/check-css.mjs",
    "security:scan": "node scripts/scan-secrets.mjs",
    "test:integration": "node scripts/test-server.mjs",
    "test:backend-activation": "node scripts/test-backend-activation.mjs",
    "test:production-security": "node scripts/test-production-security.mjs",
    "test:cookies": "node scripts/test-cookie-consent.mjs",
    "test:backup-restore": "node scripts/test-backup-restore.mjs",
    "test:preview-security": "node scripts/test-preview-security.mjs",
    "test:session-restart": "node scripts/test-session-restart.mjs",
    "test:database-migration": "node scripts/test-database-migration.mjs",
    "test:azure-sql-migrations": "node scripts/validate-azure-sql-migrations.mjs",
    "test:enterprise-migrations": "node scripts/test-enterprise-migrations.mjs",
    "test:enterprise-portal": "node scripts/test-enterprise-portal.mjs",
    "test:entra-identity": "node scripts/test-entra-identity.mjs",
    "test:secret-resolution": "node scripts/test-secret-resolution.mjs",
    "test:document-scans": "node scripts/test-document-scan-engine.mjs",
    "test:visual-contracts": "node scripts/test-visual-contracts.mjs",
    "evidence:art-direction": "node scripts/capture-art-direction-evidence.mjs",
    "test:browser-workflows": "node scripts/test-backend-browser-workflows.mjs",
    "test:browser-acceptance": "node scripts/run-browser-acceptance.mjs",
    "test": "npm run test:integration && npm run test:backend-activation && npm run test:production-security && npm run test:preview-security && npm run test:session-restart && npm run test:database-migration && npm run test:azure-sql-migrations && npm run test:enterprise-migrations && npm run test:enterprise-portal && npm run test:entra-identity && npm run test:secret-resolution && npm run test:document-scans && npm run test:cookies && npm run test:backup-restore",
    "check": "npm run docs:enterprise && npm run build && npm run visual:validate && npm run visual:modules && npm run validate && npm run syntax && npm run security:scan && npm run test:visual-contracts && npm run seo:indexnow:dry-run && npm test",
    "backup:database": "node scripts/backup-database.mjs",
    "verify:backup": "node scripts/verify-database-backup.mjs",
    "restore:database": "node scripts/restore-database.mjs",
    "migrate:azure-sql": "node scripts/migrate-sqlite-to-azure-sql.mjs",
    "migrate:azure-sql:schema": "node scripts/migrate-azure-sql-schema.mjs",
    "optimise:images": "node scripts/optimise-images.mjs",
    "optimise:modules": "node scripts/materialize-module-media.mjs"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@azure/monitor-opentelemetry": "1.18.2",
    "@azure/storage-blob": "12.33.0",
    "dotenv": "^17.4.2",
    "mssql": "12.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "playwright": "1.61.1",
    "sharp": "^0.34.5"
  }
}
