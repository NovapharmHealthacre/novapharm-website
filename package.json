{
  "name": "novapharm-healthcare-website",
  "version": "3.1.0",
  "private": true,
  "type": "module",
  "description": "Enterprise-grade NovaPharm Healthcare website with secure portal, linked entity authority, SEO/GEO controls, and SharePoint integration architecture.",
  "scripts": {
    "build": "node scripts/build-site.mjs",
    "build:base": "node scripts/build-pages.mjs",
    "seo:enhance": "node scripts/enhance-seo-authority.mjs",
    "seo:validate": "node scripts/validate-seo-authority.mjs",
    "seo:indexnow:dry-run": "node scripts/indexnow.mjs",
    "start": "node server.mjs",
    "start:production": "node --import @azure/monitor-opentelemetry/loader server.mjs",
    "prepare:release": "npm run build",
    "validate": "node scripts/validate-site.mjs && node scripts/validate-seo-authority.mjs && node scripts/check-links.mjs && node scripts/validate-app.mjs && node scripts/validate-domain.mjs && node scripts/audit-public-claims.mjs",
    "validate:site": "node scripts/validate-site.mjs",
    "validate:app": "node scripts/validate-app.mjs",
    "validate:domain": "node scripts/validate-domain.mjs",
    "audit:claims": "node scripts/audit-public-claims.mjs",
    "check:links": "node scripts/check-links.mjs",
    "syntax": "node scripts/check-syntax.mjs && node scripts/check-css.mjs",
    "security:scan": "node scripts/scan-secrets.mjs",
    "test:integration": "node scripts/test-server.mjs",
    "test:production-security": "node scripts/test-production-security.mjs",
    "test:cookies": "node scripts/test-cookie-consent.mjs",
    "test:backup-restore": "node scripts/test-backup-restore.mjs",
    "test:preview-security": "node scripts/test-preview-security.mjs",
    "test:session-restart": "node scripts/test-session-restart.mjs",
    "test:database-migration": "node scripts/test-database-migration.mjs",
    "test:entra-identity": "node scripts/test-entra-identity.mjs",
    "test:secret-resolution": "node scripts/test-secret-resolution.mjs",
    "test:document-scans": "node scripts/test-document-scan-engine.mjs",
    "test:visual-contracts": "node scripts/test-visual-contracts.mjs",
    "test:browser-acceptance": "node scripts/run-browser-acceptance.mjs",
    "test": "npm run test:integration && npm run test:production-security && npm run test:preview-security && npm run test:session-restart && npm run test:database-migration && npm run test:entra-identity && npm run test:secret-resolution && npm run test:document-scans && npm run test:cookies && npm run test:backup-restore",
    "check": "npm run build && npm run validate && npm run syntax && npm run security:scan && npm run test:visual-contracts && npm run seo:indexnow:dry-run && npm test",
    "backup:database": "node scripts/backup-database.mjs",
    "verify:backup": "node scripts/verify-database-backup.mjs",
    "restore:database": "node scripts/restore-database-backup.mjs",
    "migrate:azure-sql": "node scripts/migrate-sqlite-to-azure-sql.mjs",
    "migrate:azure-sql:schema": "node scripts/migrate-azure-sql-schema.mjs",
    "optimise:images": "node scripts/optimise-images.mjs"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@azure/monitor-opentelemetry": "1.18.2",
    "@azure/storage-blob": "12.33.0",
    "dotenv": "^17.4.2",
    "mssql": "12.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "playwright": "1.61.1"
  }
}
