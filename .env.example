NODE_ENV=production
HOST=0.0.0.0
SITE_URL=https://novapharmhealthcare.com
PUBLIC_ORIGIN=https://novapharmhealthcare.com
PUBLIC_API_ORIGIN=https://novapharmhealthcare.com
DATABASE_PATH=/var/lib/novapharm/novapharm.sqlite
DATABASE_BACKUP_ROOT=/var/lib/novapharm/backups
SECURE_CONTENT_ROOT=/var/lib/novapharm/secure-content
DOCUMENT_STORAGE_ROOT=/var/lib/novapharm/documents
SESSION_SECRET=replace-with-at-least-32-random-bytes
SESSION_TTL_MS=28800000
PREVIEW_MODE=false
PREVIEW_ACCESS_USERNAME=
PREVIEW_ACCESS_PASSWORD=

# One-time administrator bootstrap. Enter the password only in a protected
# deployment secret input, then remove this variable after the first change.
PORTAL_USERNAME=Vishal
PORTAL_DISPLAY_NAME=Vishal Chakravarty
BOOTSTRAP_ADMIN_PASSWORD=

# Static PBKDF2 provisioning is an alternative to bootstrap, never an addition.
# PORTAL_PASSWORD_SALT=generate-securely
# PORTAL_PASSWORD_HASH=generate-securely
# PORTAL_MUST_CHANGE_PASSWORD=true

# Optional additional users. Use PBKDF2 hashes only.
# PORTAL_USERS_JSON=[{"username":"customer@example.com","displayName":"Customer User","role":"client","passwordHash":"...","passwordSalt":"...","accessScopes":["customer"],"customerId":"..."}]

# Transactional contact email through Resend.
RESEND_API_KEY=
EMAIL_FROM=NovaPharm Healthcare <website@notifications.novapharmhealthcare.com>
CONTACT_NOTIFICATION_TO=

# Microsoft Graph and SharePoint.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SHAREPOINT_HOSTNAME=your-tenant.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/your-site
SHAREPOINT_DRIVE_ID=
SHAREPOINT_EXECUTIVE_PLATFORM_PATH=your-controlled-library-folder
SECURE_CONTENT_MAX_FILE_BYTES=26214400

# Polar Speed or Marken warehouse integration. Enable only against an approved API contract.
POLAR_SPEED_API_BASE_URL=
POLAR_SPEED_API_KEY=
POLAR_SPEED_ACCOUNT_NUMBER=
POLAR_SPEED_RESERVE_STOCK_PATH=
POLAR_SPEED_DISPATCH_PATH=
POLAR_SPEED_TRACKING_PATH=
POLAR_SPEED_INVENTORY_PATH=
POLAR_SPEED_TIMEOUT_MS=30000

# Finance provider.
FINANCE_API_BASE_URL=
FINANCE_API_KEY=

# Microsoft Entra ID production SSO target.
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=https://novapharmhealthcare.com/api/auth/entra/callback
